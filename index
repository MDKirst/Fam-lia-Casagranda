<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Árvore Casagranda — organograma</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --papel:#E7E0CE;
  --card:#F3EEE0;
  --card-sombra:#D8CFB6;
  --tinta:#2B3A5C;
  --tinta-suave:#66739A;
  --linha:#B7AE93;
  --carimbo:#A03D2E;
  --oliva:#4A6B47;
  --geraco:0;
}
*{margin:0;padding:0;box-sizing:border-box}
body{
  background:
    radial-gradient(circle at 20% 10%, rgba(255,255,255,.18), transparent 40%),
    var(--papel);
  color:var(--tinta);
  font-family:'Courier Prime',monospace;
  min-height:100vh;
}

/* ---------- barra de topo ---------- */
.topo{
  position:sticky;top:0;z-index:50;
  background:var(--papel);
  border-bottom:1px solid var(--card-sombra);
  padding:14px 18px;
  display:flex;align-items:center;gap:14px;flex-wrap:wrap;
}
.topo h1{
  font-family:'Special Elite',cursive;
  font-size:clamp(16px,3.5vw,22px);
  font-weight:400;flex:1;min-width:180px;
}
.topo .acoes{display:flex;gap:8px;flex-wrap:wrap}
.topo button{
  font-family:'Courier Prime',monospace;font-size:13px;
  background:var(--card);color:var(--tinta);
  border:1px solid var(--tinta-suave);padding:8px 12px;cursor:pointer;
}
.topo button:hover{background:var(--card-sombra)}
.topo button:focus-visible{outline:2px solid var(--carimbo);outline-offset:2px}
.dica{font-size:12px;color:var(--tinta-suave);width:100%;margin-top:2px}

/* ---------- área de scroll ---------- */
.palco{
  overflow:auto;
  padding:36px 24px 80px;
  min-height:calc(100vh - 60px);
}
.arvore{display:inline-flex;flex-direction:column;gap:6px;min-width:100%}

/* ---------- nó ---------- */
ul.galhos{list-style:none;padding-left:30px;position:relative}
ul.galhos.raiz{padding-left:0}
li.no{position:relative;padding:6px 0}

/* linhas de conexão */
ul.galhos:not(.raiz)>li.no::before{
  content:"";position:absolute;left:-16px;top:0;bottom:0;
  border-left:2px solid var(--linha);
}
ul.galhos:not(.raiz)>li.no:last-child::before{bottom:auto;height:28px}
ul.galhos:not(.raiz)>li.no::after{
  content:"";position:absolute;left:-16px;top:28px;width:14px;
  border-top:2px solid var(--linha);
}

/* card da pessoa */
.pcard{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--card);
  border:1px solid var(--card-sombra);
  border-left:4px solid var(--cor,#66739A);
  padding:9px 13px;cursor:default;
  max-width:100%;
  transition:transform .12s, box-shadow .12s;
}
.pcard.tem-filhos{cursor:pointer}
.pcard.tem-filhos:hover{transform:translateX(2px);box-shadow:2px 2px 0 var(--card-sombra)}
.pcard:focus-visible{outline:2px solid var(--carimbo);outline-offset:2px}
@media (prefers-reduced-motion: reduce){.pcard{transition:none}}

.toggle{
  font-family:'Special Elite',cursive;font-size:15px;
  width:20px;height:20px;flex-shrink:0;
  display:inline-flex;align-items:center;justify-content:center;
  border:1px solid var(--cor,#66739A);color:var(--cor,#66739A);
  border-radius:3px;background:transparent;
}
.pcard.folha .toggle{border-style:dotted;opacity:.4}
.pcard.aberto .toggle{background:var(--cor,#66739A);color:var(--card)}

.pinfo{display:flex;flex-direction:column;line-height:1.35;min-width:0}
.pnome{font-weight:700;font-size:15px;white-space:nowrap}
.pnome .mais{color:var(--carimbo);font-size:12px}
.pmeta{font-size:12px;color:var(--tinta-suave);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:260px}
.pcont{
  font-size:11px;color:var(--card);background:var(--cor,#66739A);
  padding:1px 7px;border-radius:10px;white-space:nowrap;flex-shrink:0;
}

/* filhos escondidos por padrão */
li.no>ul.galhos{display:none}
li.no.expandido>ul.galhos{display:block}

/* painel de detalhe */
.detalhe{
  position:fixed;right:0;top:0;bottom:0;width:min(340px,86vw);
  background:var(--card);border-left:2px solid var(--tinta);
  padding:24px 22px;z-index:100;overflow:auto;
  transform:translateX(100%);transition:transform .22s;
}
.detalhe.aberto{transform:translateX(0)}
@media (prefers-reduced-motion: reduce){.detalhe{transition:none}}
.detalhe h2{font-family:'Special Elite',cursive;font-size:22px;font-weight:400;margin-bottom:4px;padding-right:30px}
.detalhe .fechar{position:absolute;top:16px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:var(--tinta)}
.detalhe dl{margin-top:18px}
.detalhe dt{font-size:12px;color:var(--tinta-suave);text-transform:uppercase;letter-spacing:1px;margin-top:14px}
.detalhe dd{font-size:15px;margin-top:2px}
.detalhe .geracao-tag{display:inline-block;font-size:12px;background:var(--tinta);color:var(--card);padding:3px 10px;margin-top:8px}
.overlay{position:fixed;inset:0;background:rgba(43,58,92,.25);z-index:99;display:none}
.overlay.aberto{display:block}

/* legenda de cores */
.legenda-cor{display:flex;gap:16px;flex-wrap:wrap;font-size:12px;color:var(--tinta-suave);width:100%;margin-top:6px}
.legenda-cor span{display:inline-flex;align-items:center;gap:5px}
.legenda-cor i{width:12px;height:12px;display:inline-block;border-radius:2px}
</style>
</head>
<body>

<div class="topo">
  <h1>Família Casagranda</h1>
  <div class="acoes">
    <button id="bTronco">Só o tronco</button>
    <button id="bTudo">Abrir tudo</button>
    <button id="bFechar">Recolher</button>
  </div>
  <p class="dica">Toque num quadro com <b>+</b> para abrir os filhos. Toque no nome para ver os detalhes.</p>
  <div class="legenda-cor">
    <span><i style="background:#66739A"></i>tronco / geração antiga</span>
    <span><i style="background:#4A6B47"></i>vivos em 1997</span>
