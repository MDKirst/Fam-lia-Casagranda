const GERACOES = ["Casal fundador","Filho(a)","Neto(a)","Bisneto(a)","Tataraneto(a)","5ª geração"];
const cor = p => p.m ? "#A03D2E" : (p.tronco ? "#66739A" : "#4A6B47");
const esc = s => (s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
const contar = l => l ? l.reduce((t,p)=>t+1+contar(p.f),0) : 0;

let seq = 0;
const REG = {};

function montarNo(p, ger){
  const id = "n"+(seq++);
  REG[id] = {p, ger};
  const temF = p.f && p.f.length;
  const total = contar(p.f);
  const li = document.createElement("li");
  li.className = "no";
  li.dataset.id = id;

  const card = document.createElement("div");
  card.className = "pcard" + (temF?" tem-filhos":" folha");
  card.style.setProperty("--cor", cor(p));
  card.tabIndex = 0;
  card.innerHTML =
    `<span class="toggle">${temF?"+":"·"}</span>
     <span class="pinfo">
       <span class="pnome">${esc(p.n)}${p.m?' <span class="mais">(+)</span>':''}</span>
       ${p.d||p.cj?`<span class="pmeta">${esc([p.d, p.cj?("C/ "+p.cj):""].filter(Boolean).join(" · "))}</span>`:""}
     </span>
     ${temF?`<span class="pcont">${total}</span>`:""}`;
  li.appendChild(card);

  if(temF){
    const ul = document.createElement("ul");
    ul.className = "galhos";
    p.f.forEach(c => ul.appendChild(montarNo(c, ger+1)));
    li.appendChild(ul);
    card.addEventListener("click", e=>{
      if(e.detail===0) return;
      li.classList.toggle("expandido");
      card.classList.toggle("aberto");
      card.querySelector(".toggle").textContent = li.classList.contains("expandido")?"–":"+";
    });
  }
  card.addEventListener("keydown", e=>{
    if(e.key==="Enter"||e.key===" "){ e.preventDefault(); card.click(); }
  });
  card.addEventListener("dblclick", ()=>abrirDetalhe(id));
  // clique no nome abre detalhe sem alternar
  card.querySelector(".pnome").addEventListener("click", e=>{ e.stopPropagation(); abrirDetalhe(id); });
  return li;
}

const raiz = document.getElementById("raiz");
raiz.appendChild(montarNo(RAIZ, 0));
// abre o tronco (casal + 14 filhos) por padrão
raiz.querySelector("li.no").classList.add("expandido");
raiz.querySelector(".pcard").classList.add("aberto");
raiz.querySelector(".toggle").textContent = "–";

/* ---- painel de detalhe ---- */
const detalhe = document.getElementById("detalhe");
const overlay = document.getElementById("overlay");
const detConteudo = document.getElementById("detConteudo");
function abrirDetalhe(id){
  const {p,ger} = REG[id];
  const total = contar(p.f);
  detConteudo.innerHTML =
    `<h2>${esc(p.n)}${p.m?' <span style="color:var(--carimbo);font-size:15px">(+)</span>':''}</h2>
     <span class="geracao-tag">${GERACOES[Math.min(ger,5)]}</span>
     <dl>
       ${p.d?`<dt>Nascimento</dt><dd>${esc(p.d)}</dd>`:""}
       ${p.cj?`<dt>Casamento</dt><dd>${esc(p.cj)}</dd>`:""}
       ${total?`<dt>Descendentes transcritos</dt><dd>${total}</dd>`:""}
       ${p.obs?`<dt>Observação</dt><dd>${esc(p.obs)}</dd>`:""}
       ${p.m?`<dt>Situação</dt><dd style="color:var(--carimbo)">Falecido(a) até 1997</dd>`:(ger>0?`<dt>Situação</dt><dd style="color:var(--oliva)">Vivo(a) em 1997</dd>`:"")}
     </dl>`;
  detalhe.classList.add("aberto"); overlay.classList.add("aberto");
}
function fecharDetalhe(){ detalhe.classList.remove("aberto"); overlay.classList.remove("aberto"); }
document.getElementById("bFecharDet").onclick = fecharDetalhe;
overlay.onclick = fecharDetalhe;
document.addEventListener("keydown", e=>{ if(e.key==="Escape") fecharDetalhe(); });

/* ---- botões globais ---- */
function setTodos(expandir){
  document.querySelectorAll("li.no").forEach(li=>{
    const card = li.querySelector(":scope > .pcard");
    if(!card.classList.contains("tem-filhos")) return;
    li.classList.toggle("expandido", expandir);
    card.classList.toggle("aberto", expandir);
    card.querySelector(".toggle").textContent = expandir?"–":"+";
  });
}
document.getElementById("bTudo").onclick = ()=>setTodos(true);
document.getElementById("bFechar").onclick = ()=>{
  setTodos(false);
  const r = raiz.querySelector("li.no");
  r.classList.add("expandido");
  r.querySelector(".pcard").classList.add("aberto");
  r.querySelector(".toggle").textContent="–";
};
document.getElementById("bTronco").onclick = ()=>{
  setTodos(false);
  const r = raiz.querySelector("li.no");
  r.classList.add("expandido");
  r.querySelector(".pcard").classList.add("aberto");
  r.querySelector(".toggle").textContent="–";
};
</script>
</body>
